# 공용 웹호스팅 환경 설정 샘플
#
# 이 파일을 복사하여 프로젝트 루트의 .env 파일을 만들고,
# 실제 호스팅 환경 정보로 수정한다.
#
# @see docs/shared-hosting-target-baseline.md

# 애플리케이션 이름
WIKI_APP_NAME=wiki-engine

# 실행 환경 (development, staging, production)
WIKI_ENVIRONMENT=production

# 데이터베이스 연결 (Python/SQLAlchemy 형식)
# 호스팅 패널에서 제공되는 정보로 수정:
# mysql://[사용자명]:[비밀번호]@[호스트]/[데이터베이스명]
WIKI_DATABASE_URL=mysql://wiki_user:your-password@localhost:3306/wiki_engine

# 캐시 저장소 (선택사항 - 첫 배포에서는 설정하지 않아도 됨)
# WIKI_REDIS_URL=redis://localhost:6379/0

# PHP/PDO 특화 MariaDB 연결
# mysql:host=[호스트];port=[포트];dbname=[데이터베이스명];charset=utf8mb4
WIKI_MARIADB_DSN=mysql:host=localhost;port=3306;dbname=wiki_engine;charset=utf8mb4
