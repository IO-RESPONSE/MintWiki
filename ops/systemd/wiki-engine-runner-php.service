[Unit]
Description=Wiki Engine PHP track task runner
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/wiki-engine-php-track
Environment=WIKI_ENGINE_REPO=/root/wiki-engine-php-track
Environment=WIKI_ENGINE_LOCK=/tmp/wiki-engine-runner-php.lock
Environment=WIKI_ENGINE_TASK_MIN=0351
Environment=WIKI_ENGINE_TASK_MAX=0440
Environment=WIKI_ENGINE_GIT_SYNC=0
Environment=WIKI_ENGINE_SKIP_PROGRESS=1
Environment=HOME=/root
Environment=WIKI_ENGINE_AGENT=codex
Environment=CLAUDE_BIN=/root/.local/bin/claude
Environment=CLAUDE_MODEL=sonnet
Environment=CLAUDE_PERMISSION_MODE=acceptEdits
Environment=CLAUDE_OUTPUT_FORMAT=json
Environment=CODEX_BIN=/root/.nvm/versions/node/v22.22.2/bin/codex
Environment=CODEX_SANDBOX=workspace-write
Environment=CODEX_APPROVAL=never
ExecStart=/root/wiki-engine-php-track/scripts/run-next-task.sh
TimeoutStartSec=540
