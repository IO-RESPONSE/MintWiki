[Unit]
Description=Wiki Engine Codex non-interactive task runner
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/wiki-engine-blueprint
Environment=WIKI_ENGINE_REPO=/root/wiki-engine-blueprint
Environment=WIKI_ENGINE_LOCK=/tmp/wiki-engine-runner.lock
Environment=WIKI_ENGINE_TASK_MAX=0670
Environment=HOME=/root
Environment=WIKI_ENGINE_AGENT=codex
Environment=CLAUDE_BIN=/root/.local/bin/claude
Environment=CLAUDE_MODEL=sonnet
Environment=CLAUDE_PERMISSION_MODE=acceptEdits
Environment=CLAUDE_OUTPUT_FORMAT=json
Environment=CODEX_BIN=/root/.nvm/versions/node/v22.22.2/bin/codex
Environment=CODEX_SANDBOX=workspace-write
Environment=CODEX_APPROVAL=never
Environment=GITHUB_TOKEN_FILE=/root/.github-mintwiki-token
ExecStart=/root/wiki-engine-blueprint/scripts/run-next-task.sh
TimeoutStartSec=1200
